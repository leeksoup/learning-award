{
    "name": "drupal/anu_lms",
    "description": "Deceptively simple learning management system (LMS) for individual teachers, educational organisations and businesses.",
    "type": "drupal-module",
    "keywords": ["Drupal", "LMS"],
    "homepage": "https://drupal.org/project/anu_lms",
    "support": {
        "issues": "https://www.drupal.org/project/issues/anu_lms",
        "source": "https://git.drupalcode.org/project/anu_lms"
    },
    "license": "GPL-2.0-or-later",
    "require": {
        "cweagans/composer-patches": "^1.0||^2",
        "symfony/translation": "^4.0||^6.0||^7.0",
        "drupal/allowed_formats": "^2.0||^3.0",
        "drupal/core": "^10.0||^11.0",
        "drupal/eck": "^2.0",
        "drupal/field_group": "^3.0",
        "drupal/inline_entity_form": "^1.0@RC||^3.0@RC",
        "drupal/paragraphs": "^1.0",
        "drupal/paragraphs_browser": "^1.2",
        "drupal/paragraphs_selection": "^2.0",
        "drupal/rest_entity_recursive": "^2.0@RC",
        "drupal/weight": "^3.0"
    },
    "replace": {
        "drupal/ckeditor5": "self.version"
    },
    "suggest": {
        "drupal/pwa": "Allows using Anu LMS offline."
    },
    "extra": {
        "enable-patching": true,
        "patches": {
            "drupal/core": {
                "Make exposed filter values available as tokens for text areas": "https://www.drupal.org/files/issues/2022-10-30/2761273-50.patch"
            },
            "drupal/entity_reference_revisions": {
                "Do not resave field item": "https://www.drupal.org/files/issues/2024-03-18/entity_reference_revisions-3431223-2.patch"
            },
            "drupal/paragraphs_browser": {
                "#3275985 FIx fieldsets overlapping when using Gin admin theme": "https://www.drupal.org/files/issues/2023-11-06/fieldset-overlap-gin-theme-3275985-13.patch",
                "#3307156 Does not support custom paragraph bundle filtering widgets": "https://www.drupal.org/files/issues/2023-01-24/paragraphs_browser-add-support-of-custom-paragraphs-bundle-filtering-widgets-3307156-3_0.patch"
            }
        }
    }
}
